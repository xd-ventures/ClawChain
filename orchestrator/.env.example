# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
OPERATOR_KEYPAIR_PATH=~/.config/solana/id.json

# GCP (uses Container-Optimized OS — no custom base image needed)
GCP_PROJECT_ID=your-gcp-project
GCP_ZONE=europe-central2-a
GCP_MACHINE_TYPE=e2-micro
GCP_NETWORK=default
GCP_SERVICE_ACCOUNT_EMAIL=

# PicoClaw container image (pulled automatically by COS)
PICOCLAW_IMAGE=docker.io/sipeed/picoclaw:latest

# Secrets
OPENROUTER_API_KEY=sk-or-...

# Bot pool
TELEGRAM_BOTS_FILE=./telegram_bots.txt

# Database
SQLITE_DB_PATH=./orchestrator.db

# Intervals
POLL_INTERVAL_SECS=15
BILLING_INTERVAL_SECS=3600

# Mock mode — set to a YAML file path to skip real Solana RPC and GCP.
# No operator keypair or GCP project needed. Edit the YAML to simulate chain state.
# MOCK_STATE_FILE=./mock_state.yaml
